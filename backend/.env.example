PORT=3000
NODE_ENV=development

MONGODB_URI=YOUR_MONGODB_URI_HERE

JWT_SECRET=CHANGE_THIS_TO_A_SECURE_VALUE
JWT_EXPIRE=7d

CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=YOUR_EMAIL_HERE
EMAIL_PASS=YOUR_EMAIL_PASSWORD_HERE

CORS_ORIGINS=http://localhost:3001

# ─── Email (OTP Verification) ──────────────────────────────────────────────────
# IMPORTANT: Gmail stopped accepting regular passwords for SMTP in August 2024.
#
# You MUST use a Gmail App Password, NOT your regular Gmail password.
#
# How to generate a Gmail App Password:
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Go to App Passwords: https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer" (or any device)
# 4. Copy the 16-character password shown (format: xxxx xxxx xxxx xxxx)
# 5. Paste it here WITHOUT spaces (e.g., xxxxxxxxxxxxxxxx)
#
# Alternative for development: Use Mailtrap (free, no real emails sent)
# Sign up at https://mailtrap.io → Inbox → SMTP Settings → copy values below
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password_no_spaces
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
